{
  "compilerOptions": {
    "target": "ES2022",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "sourceMap": true,
    "outDir": "./dist",
    "rootDir": ".",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true,
    "baseUrl": ".",
    "paths": {
      "pages/*": ["pages/*"],
      "@pages/*": ["pages/*"],
      "api/*": ["api/*"],
      "@api/*": ["api/*"],
      "fixtures/*": ["fixtures/*"],
      "@fixtures/*": ["fixtures/*"],
      "utils/*": ["utils/*"],
      "@utils/*": ["utils/*"],
      "test-data/*": ["test-data/*"],
      "@test-data/*": ["test-data/*"]
    }
  },
  "include": [
    "tests/**/*.ts",
    "pages/**/*.ts",
    "api/**/*.ts",
    "fixtures/**/*.ts",
    "utils/**/*.ts",
    "test-data/**/*.ts",
    "playwright.config.ts"
  ],
  "exclude": [
    "node_modules",
    "dist"
  ]
}
